# remotectl server 配置示例
# 启动参数优先，环境变量次之，此文件仅供参考

# 监听地址
addr: ":8080"

# 控制端连接密码（viewer password）
password: "your-strong-password"

# TLS（生产环境必须开启）
tls_cert: "/certs/fullchain.pem"
tls_key:  "/certs/privkey.pem"

# 设备 token 通过环境变量配置：
# REMOTECTL_TOKEN_<device_id>=<token>
# 例：
#   REMOTECTL_TOKEN_office-mac=abc123secret
#   REMOTECTL_TOKEN_home-win=xyz789secret
# 若不配置任何 token，则运行在开发模式（所有 agent 均可连入）
