!deploy/certs/.gitkeep
*.crt
*.key
*.pem

# ── 编译产物 ─────────────────────────────────────────────────
server/server
server/remotectl-server*
server/static/
deploy/bin/*
!deploy/bin/.gitkeep
deploy/static/*
!deploy/static/.gitkeep

# ── Go ───────────────────────────────────────────────────────
vendor/

# ── Agent 构建产物 & 平台依赖库 ───────────────────────────────
agent/pipeline/x264/
agent/*.exe
agent/remotectl-agent*

# ── Node / 前端 ──────────────────────────────────────────────
client/node_modules/
client/dist/

