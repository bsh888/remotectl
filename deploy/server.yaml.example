# remotectl server configuration
# Copy to server.yaml and edit before starting.

addr: ":443"

# 管理后台密码（留空则禁用管理后台）
admin_password: ""

# 当前版本号，用于首页下载链接（留空则显示"前往 Releases"）
version: ""

# ── 会话密码（由 agent 自动管理，服务端无需配置）──────────────────────────────
#
# 被控端每次启动时随机生成 8 位数字，显示在 App"共享本机"页面。
# 控制端输入设备 ID + 此 8 位密码即可连接，无需其他密码。

tls_cert: "./certs/server.crt"
tls_key:  "./certs/server.key"
static:   "./static"

# ── Agent 认证（必填）────────────────────────────────────────────────────────
#
# 按设备 ID 单独配置 token，agent 启动时用 HMAC-SHA256 验证。
# key = 9 位设备 ID（agent 首次运行自动生成，见 App"共享本机"页面）。
# value = 自定义强密钥（与 deploy/agent.yaml 中的 token 字段一致）。
tokens:
  123456789: "replace-with-a-strong-secret"
# 添加更多设备：
# 987654321: "another-device-secret"

# ── TURN 中继 ─────────────────────────────────────────────────────────────────
# 移动网络（4G/5G）/ 对称型 NAT 必须配置，否则会出现 "WebRTC connection failed"。
# 局域网内使用可留空。
#
# 推荐在服务器上安装 coturn：sudo apt install coturn
# /etc/turnserver.conf 配置：lt-cred-mech + user=remotectl:changeme
# 防火墙需放行：UDP/TCP 3478、UDP 49152-65535
#
# OCI 用户注意：需同时在 OCI 安全列表 AND 实例 iptables 中放行上述端口。
turn:
  url:      ""            # e.g. turn:1.2.3.4:3478（填服务器公网 IP）
  user:     "remotectl"   # 与 coturn /etc/turnserver.conf 中 user= 用户名一致
  password: "changeme"    # 与 coturn /etc/turnserver.conf 中 user= 密码一致
