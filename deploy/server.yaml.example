# remotectl server configuration
# Copy to server.yaml and edit before starting.

addr: ":8443"

# ── Layer 1：服务器密码（必填）─────────────────────────────────────────────────
#
# 控制端连接信令服务器时必须提供此密码，用于阻止未授权方访问服务器上任何设备。
# 控制端 App"服务器密码"字段 / Web 端"服务器密码"输入框填此值。
password: "your-server-password"

# ── Layer 2：会话密码（由 agent 自动管理，服务端无需配置）──────────────────────
#
# 被控端每次启动时随机生成 8 位数字，显示在 App"共享本机"页面。
# 控制端必须输入此密码才能连到具体设备，Layer 1 通过后才会检查 Layer 2。

tls_cert: "./certs/server.crt"
tls_key:  "./certs/server.key"
static:   "./static"

# ── Agent 认证（必填）────────────────────────────────────────────────────────
#
# 按设备 ID 单独配置 token，agent 启动时用 HMAC-SHA256 验证。
# key = 9 位设备 ID（agent 首次运行自动生成，见 App"共享本机"页面）。
# value = 自定义强密钥（与 deploy/agent.yaml 中的 token 字段一致）。
tokens:
  123456789: "replace-with-a-strong-secret"
# 添加更多设备：
# 987654321: "another-device-secret"

# ── TURN 中继 ─────────────────────────────────────────────────────────────────
# 移动网络 / 对称型 NAT 必须配置，否则会出现 "WebRTC connection failed"。
# 局域网内使用可留空。
#
# 使用 docker-compose 时，coturn 已内置，将下方 url 改为服务器公网 IP 即可。
# turn.user / turn.password 须与 docker-compose.yml 中 coturn 的 --user 参数一致。
#
# OCI 用户注意：需同时在 OCI 安全列表 AND 实例 iptables 中放行：
#   UDP/TCP 3478  (TURN/STUN)
#   UDP 49152-65535  (TURN 中继数据)
turn:
  url:      ""                  # e.g. turn:1.2.3.4:3478（填服务器公网 IP）
  user:     "remotectl"         # 须与 docker-compose.yml coturn --user 一致
  password: "changeme"          # 须与 docker-compose.yml coturn --user 的密码一致
